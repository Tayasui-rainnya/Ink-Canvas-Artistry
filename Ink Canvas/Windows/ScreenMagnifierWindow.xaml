<Window x:Class="Ink_Canvas.Windows.ScreenMagnifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenMagnifierWindow"
        Width="420"
        Height="260"
        MinWidth="260"
        MinHeight="180"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None">
    <Border BorderBrush="#FFEAB308"
            BorderThickness="2"
            CornerRadius="6"
            Background="#CC111827"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ClipToBounds="True">
                <Image x:Name="MagnifierImage" Stretch="Fill" />
                <Thumb x:Name="LeftResizeThumb"
                       Width="10"
                       HorizontalAlignment="Left"
                       Cursor="SizeWE"
                       Background="#66F8FAFC" />
                <Thumb x:Name="RightResizeThumb"
                       Width="10"
                       HorizontalAlignment="Right"
                       Cursor="SizeWE"
                       Background="#66F8FAFC" />
                <Thumb x:Name="TopResizeThumb"
                       Height="10"
                       VerticalAlignment="Top"
                       Cursor="SizeNS"
                       Background="#66F8FAFC" />
            </Grid>

            <Border Grid.Row="1"
                    Background="#F81F2937"
                    BorderBrush="#FF374151"
                    BorderThickness="0,1,0,0"
                    Padding="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="DragHandleBorder"
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Cursor="SizeAll"
                            CornerRadius="4"
                            Background="#FF111827"
                            BorderBrush="#FF9CA3AF"
                            BorderThickness="1">
                        <TextBlock Text="⣿"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FFF9FAFB"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <Button Grid.Column="1"
                            Width="26"
                            Height="26"
                            Margin="0,0,8,0"
                            Content="-"
                            Click="ZoomOutButton_Click" />

                    <Slider x:Name="ZoomSlider"
                            Grid.Column="2"
                            Minimum="1.5"
                            Maximum="5.0"
                            Value="2.5"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            VerticalAlignment="Center"
                            ValueChanged="ZoomSlider_ValueChanged" />

                    <Button Grid.Column="3"
                            Width="26"
                            Height="26"
                            Margin="8,0,0,0"
                            Content="+"
                            Click="ZoomInButton_Click" />

                    <TextBlock x:Name="ZoomText"
                               Grid.Column="4"
                               Margin="8,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="#FFF3F4F6"
                               FontWeight="SemiBold"
                               Text="2.5x" />

                    <Button Grid.Column="5"
                            Width="26"
                            Height="26"
                            Content="×"
                            Click="CloseButton_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
