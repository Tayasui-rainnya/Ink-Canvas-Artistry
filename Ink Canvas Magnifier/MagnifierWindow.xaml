<Window x:Class="Ink_Canvas_Magnifier.MagnifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ink Canvas 放大镜"
        Width="420"
        Height="320"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True">
    <Border BorderBrush="#FF111111"
            BorderThickness="2"
            CornerRadius="6"
            Background="#CCF1F200">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="44" />
            </Grid.RowDefinitions>

            <Grid>
                <Border BorderBrush="#FFFFFFFF"
                        BorderThickness="2"
                        CornerRadius="4"
                        Margin="3"
                        Background="#FF000000">
                    <Image x:Name="MagnifiedImage"
                           Stretch="Fill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>

                <Thumb x:Name="LeftResizeThumb"
                       Width="12"
                       HorizontalAlignment="Left"
                       Cursor="SizeWE"
                       DragDelta="LeftResizeThumb_DragDelta"
                       Background="#00000000" />
                <Thumb x:Name="RightResizeThumb"
                       Width="12"
                       HorizontalAlignment="Right"
                       Cursor="SizeWE"
                       DragDelta="RightResizeThumb_DragDelta"
                       Background="#00000000" />
            </Grid>

            <Border Grid.Row="1"
                    Background="#FF111111"
                    BorderBrush="#FFFFFFFF"
                    BorderThickness="1,2,1,1"
                    CornerRadius="0,0,6,6">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="DragHandleArea"
                            Grid.Column="0"
                            Width="30"
                            Height="30"
                            Margin="0,0,8,0"
                            Background="#FFFFFFFF"
                            CornerRadius="4"
                            MouseLeftButtonDown="DragHandleArea_MouseLeftButtonDown"
                            MouseLeftButtonUp="DragHandleArea_MouseLeftButtonUp"
                            MouseMove="DragHandleArea_MouseMove"
                            Cursor="SizeAll">
                        <TextBlock Text="⣿"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   Foreground="#FF111111" />
                    </Border>

                    <TextBlock Grid.Column="1"
                               x:Name="ZoomTextBlock"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="2.0x" />

                    <Button Grid.Column="2"
                            x:Name="ZoomOutButton"
                            Content="-"
                            Margin="0,4,4,4"
                            FontWeight="Bold"
                            Click="ZoomOutButton_Click" />

                    <Slider Grid.Column="3"
                            x:Name="ZoomSlider"
                            Minimum="1.5"
                            Maximum="5.0"
                            Value="2.0"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            ValueChanged="ZoomSlider_ValueChanged" />

                    <Button Grid.Column="4"
                            x:Name="ZoomInButton"
                            Content="+"
                            Margin="0,4,8,4"
                            FontWeight="Bold"
                            Click="ZoomInButton_Click" />

                    <Button Grid.Column="5"
                            Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            Content="×"
                            Foreground="White"
                            Background="#FFC62828"
                            BorderBrush="#FFFFFFFF"
                            BorderThickness="1"
                            FontWeight="Bold"
                            Click="CloseButton_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
